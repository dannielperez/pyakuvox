# -------------------------------------------------------------------
# akuvox-api environment configuration
# Copy to .env and fill in your values
# -------------------------------------------------------------------

# -- Local device connection --
AKUVOX_LOCAL_HOST=192.168.1.100
AKUVOX_LOCAL_PORT=80
AKUVOX_LOCAL_USERNAME=admin
AKUVOX_LOCAL_PASSWORD=admin
# Auth method: none | allowlist | basic | digest
AKUVOX_LOCAL_AUTH_TYPE=digest
AKUVOX_LOCAL_USE_SSL=false
AKUVOX_LOCAL_VERIFY_SSL=false
AKUVOX_LOCAL_TIMEOUT=10

# -- Cloud / SmartPlus (EXPERIMENTAL - all cloud features are unverified) --
AKUVOX_CLOUD_PHONE_NUMBER=
AKUVOX_CLOUD_COUNTRY_CODE=
AKUVOX_CLOUD_AUTH_TOKEN=
AKUVOX_CLOUD_TOKEN=
AKUVOX_CLOUD_SUBDOMAIN=ecloud
# Regional subdomains: ecloud (EMEA), ucloud (Americas), scloud (APAC),
#   jcloud (APAC2), ccloud (China), rucloud (Russia), aucloud (AU)

# -- General --
AKUVOX_DEBUG=false
AKUVOX_LOG_LEVEL=INFO
# Set to true to log full request/response bodies (passwords redacted)
AKUVOX_LOG_HTTP_BODIES=false
